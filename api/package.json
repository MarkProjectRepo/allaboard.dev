{
  "name": "allaboard-migrations",
  "private": true,
  "scripts": {
    "migrate": "npx tsx knexfile.ts migrate",
    "migrate:make": "npx tsx knexfile.ts migrate:make",
    "rollback": "npx tsx knexfile.ts rollback",
    "seed": "npx tsx knexfile.ts seed",
    "db:reset": "npx tsx knexfile.ts rollback && npx tsx knexfile.ts migrate && npx tsx knexfile.ts seed",
    "db:create": "/opt/homebrew/opt/postgresql@14/bin/psql -U postgres -h localhost -c \"CREATE DATABASE allaboard;\"",
    "db:ping": "/opt/homebrew/opt/postgresql@14/bin/psql -U postgres -h localhost -c \"SELECT version();\""
  },
  "dependencies": {
    "knex": "^3.1.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
